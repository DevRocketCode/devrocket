---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import StatRow from '../components/StatRow.astro';
import CapabilityCards from '../components/CapabilityCards.astro';
import SystemCards from '../components/SystemCards.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FounderBio from '../components/FounderBio.astro';
import Testimonials from '../components/Testimonials.astro';
import ScheduleCall from '../components/ScheduleCall.astro';
import {
  capabilities,
  founder,
  founderPrinciples,
  processSteps,
  proofStats,
  systems,
  testimonials,
} from '../data/siteContent';
---

<Layout
  title="DevRocket | AI Software Engineering & Workflow Automation"
  description="Founder-led AI development for workflow automation, document processing, knowledge systems, agent workflows, and production AI products."
>
  <div class="home-container">
    <Hero />

    <section class="section-padding proof-section" aria-label="Real-world examples">
      <div class="content-container">
        <div class="section-heading">
          <p class="eyebrow">Resume-backed outcomes</p>
          <h2 class="section-title">Real-world examples</h2>
          <p class="section-lead">
            Resume-backed examples from prior engineering work. Each metric links to the project
            context below so the result stays attached to the system that produced it.
          </p>
        </div>
        <StatRow stats={proofStats} />
      </div>
    </section>

    <section id="capabilities" class="section-padding">
      <div class="content-container">
        <div class="section-heading section-heading--split">
          <div>
            <p class="eyebrow">What DevRocket builds</p>
            <h2 class="section-title">AI systems for real workflows.</h2>
          </div>
          <p class="section-lead">
            DevRocket builds the model integration and the software around it, from user experience
            and APIs to data, deployment, and evaluation.
          </p>
        </div>
        <CapabilityCards capabilities={capabilities} />

        <div class="advisory-panel section-narrow">
          <p class="eyebrow">Secondary offering</p>
          <h3>Advisory and team enablement</h3>
          <p>
            Advisory and workshops are available when a team needs alignment on AI architecture,
            workflow design, RAG quality, evaluation, or production delivery before or after a build.
          </p>
        </div>
      </div>
    </section>

    <section id="systems" class="section-padding">
      <div class="content-container">
        <div class="section-heading">
          <p class="eyebrow">Selected work</p>
          <h2 class="section-title">AI systems shipped into production.</h2>
          <p class="section-lead">
            Representative examples from Preston's prior engineering work. Details are limited where
            client and employer work is confidential.
          </p>
        </div>
        <SystemCards systems={systems} />
      </div>
    </section>

    <section id="process" class="section-padding">
      <div class="content-container">
        <div class="section-heading section-heading--split">
          <div>
            <p class="eyebrow">How it works</p>
            <h2 class="section-title">A direct path to production.</h2>
          </div>
          <p class="section-lead">
            Start with the workflow and measurable outcome, then ship the smallest useful version
            before hardening it for real users.
          </p>
        </div>
        <ProcessSteps steps={processSteps} />
      </div>
    </section>

    <section id="about" class="section-padding">
      <div class="content-container">
        <FounderBio founder={founder} />

        <div class="principle-grid section-offset">
          {founderPrinciples.map((principle) => (
            <article>
              <h3>{principle.title}</h3>
              <p>{principle.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <Testimonials testimonials={testimonials} />

    <ScheduleCall />
  </div>
</Layout>
