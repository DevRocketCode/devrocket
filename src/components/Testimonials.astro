---
interface Testimonial {
  name: string;
  detail: string;
  image: string;
  socialUrl?: string;
  quote: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<section id="testimonials" class="section-padding testimonials-section">
  <div class="content-container">
    <div class="section-heading section-heading--split">
      <div>
        <p class="eyebrow">Testimonials</p>
        <h2 class="section-title">Clear thinking. Strong delivery.</h2>
      </div>
      <p class="section-lead">
        Real notes from people who have worked with Preston and seen the way he explains,
        builds, and delivers technical work.
      </p>
    </div>

    <div class="testimonial-grid">
      {testimonials.map((testimonial) => (
        <article class="testimonial-card">
          <div class="testimonial-card__top">
            {testimonial.socialUrl && (
              <a
                class="testimonial-linkedin"
                href={testimonial.socialUrl}
                target="_blank"
                rel="noreferrer"
                aria-label={`${testimonial.name} on LinkedIn`}
              >
                <i class="fa fa-linkedin-square" aria-hidden="true"></i>
              </a>
            )}
          </div>

          <blockquote>{testimonial.quote}</blockquote>

          <footer class="testimonial-card__footer">
            <img src={testimonial.image} alt={testimonial.name} />
            <div>
              <strong>{testimonial.name}</strong>
              <span>{testimonial.detail}</span>
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
