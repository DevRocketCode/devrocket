---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
