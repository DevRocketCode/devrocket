<section id="what-we-do" class="section-padding">
  <div class="content-container">
    <div class="section-heading">
      <p class="eyebrow">What we do</p>
      <h2 class="section-title">Focused builds for teams that need momentum</h2>
      <p class="section-lead">
        Clear software scope, senior implementation, and delivery rhythms built around operators.
      </p>
    </div>
    <div class="services-row service-grid">
      <div class="services-item service-card">
        <div class="icon">
          <i class="icon-screen-desktop"></i>
        </div>
        <h3>Web Applications</h3>
        <p>Full-stack, production-ready web apps built with modern frameworks and best practices.</p>
      </div>
      <div class="services-item service-card">
        <div class="icon">
          <i class="icon-screen-smartphone"></i>
        </div>
        <h3>Mobile Applications</h3>
        <p>iOS, Android, and cross-platform mobile apps with native performance.</p>
      </div>
      <div class="services-item service-card">
        <div class="icon">
          <i class="icon-chart"></i>
        </div>
        <h3>Internal Tools & Dashboards</h3>
        <p>Custom tools and dashboards to streamline operations and automate workflows.</p>
      </div>
      <div class="services-item service-card">
        <div class="icon">
          <i class="icon-rocket"></i>
        </div>
        <h3>Prototypes to Production</h3>
        <p>Rapid iteration from concept to working software, then scale to production.</p>
      </div>
      <div class="services-item service-card">
        <div class="icon">
          <i class="icon-link"></i>
        </div>
        <h3>Integrations & Automation</h3>
        <p>APIs, webhooks, and workflows to connect systems and automate processes.</p>
      </div>
    </div>
  </div>
</section>
