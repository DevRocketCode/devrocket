---
interface Props {
  caseStudy: {
    title: string;
    problem: string;
    solution: string;
    timeframe: string;
  };
}

const { caseStudy } = Astro.props;
---

<article class="services-item work-card">
  <h3>{caseStudy.title}</h3>
  <p><strong>Problem</strong> {caseStudy.problem}</p>
  <p><strong>Solution</strong> {caseStudy.solution}</p>
  <p><strong>Timeframe</strong> {caseStudy.timeframe}</p>
</article>
