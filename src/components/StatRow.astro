---
interface Stat {
  value: string;
  label: string;
  detail?: string;
  href?: string;
  linkLabel?: string;
}

interface Props {
  stats: Stat[];
  compact?: boolean;
}

const { stats, compact = false } = Astro.props;
---

<div class:list={['proof-strip', compact && 'proof-strip--compact']}>
  {stats.map((stat) => (
    <article class="proof-stat">
      <strong>{stat.value}</strong>
      <span>{stat.label}</span>
      {stat.detail && <p>{stat.detail}</p>}
      {stat.href && (
        <a class="proof-stat__link" href={stat.href}>
          {stat.linkLabel ?? 'Read case study'} <span aria-hidden="true">-&gt;</span>
        </a>
      )}
    </article>
  ))}
</div>
