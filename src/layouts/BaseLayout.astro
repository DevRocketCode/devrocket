---
import '../styles/site.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'DevRocket | AI Software Engineering & Workflow Automation',
  description = 'Founder-led AI development for workflow automation, document processing, knowledge systems, agent workflows, and production AI products.',
} = Astro.props;

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" href="/img/about/favicon.gif" />
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="stylesheet" href="/fonts/simple-line-icons.css" />
    <link rel="stylesheet" href="/fonts/font-awesome.min.css" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
