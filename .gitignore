# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Typescript v1 declaration files
typings/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# dotenv environment variable files
.env*

# gatsby files (legacy)
.cache/

# Astro build output
dist/
.astro/

# Gatsby build artifacts (legacy - can be removed)
public/*.js
public/*.js.map
public/*.js.LICENSE.txt
public/_gatsby/
public/~partytown/
public/page-data/
public/static/
public/chunk-map.json
public/webpack.stats.json

# Note: public/ is NOT ignored - it contains static assets (CNAME, robots.txt, images, fonts) that need to be committed
# But we ignore auto-generated JS/build files above

# Mac files
.DS_Store

# Yarn
yarn-error.log
.pnp/
.pnp.js
# Yarn Integrity file
.yarn-integrity

# Editor settings
.vscode
.idea
